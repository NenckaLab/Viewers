##
# Environment: Default
#
# We're using this to set variables for development.
# Please feel free to delete or modify this file for your own setup.
# Be careful not to commit anything sensitive to source control.
#

PUBLIC_URL=/
APP_CONFIG=config/default.js
USE_HASH_ROUTER=false
##
# EXAMPLE
#
# Read more about .env files when using create-react-app here:
# https://facebook.github.io/create-react-app/docs/adding-custom-environment-variables#adding-development-environment-variables-in-env
#

# For accessing XNAT in development mode
# XNAT_DOMAIN without trailing '/', e.g. http://10.1.1.176 or http://10.1.1.176/XNAT
XNAT_DOMAIN=https://devxnat.rcc.mcw.edu
XNAT_DOMAIN_CIR2=https://cirxnat2.rcc.mcw.edu
XNAT_USERNAME=admin
XNAT_PASSWORD=admin
XNAT_PROXY=http://localhost:3000
PROXY_TARGET=
